{
  "info": {
    "name": "TechGear API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection with at least one request per endpoint"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:5001" },
    { "key": "userToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "productId", "value": "1" },
    { "key": "cartItemId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth - Register User",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@techgear.local\",\n  \"password\": \"User123!\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login User",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@techgear.local\",\n  \"password\": \"User123!\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin\",\n  \"password\": \"Admin123!\"\n}"
        }
      }
    },
    {
      "name": "Products - Get All",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products"
      }
    },
    {
      "name": "Products - Get By Id",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products/{{productId}}"
      }
    },
    {
      "name": "Products - Create (Admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/products",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"GPU RTX 4070\",\n  \"description\": \"Great GPU\",\n  \"imageUrl\": \"https://example.com/img.jpg\",\n  \"price\": 799.99,\n  \"inventoryCount\": 10\n}"
        }
      }
    },
    {
      "name": "Products - Update (Admin)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/products/{{productId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"GPU RTX 4070 Updated\",\n  \"description\": \"Updated description\",\n  \"imageUrl\": \"https://example.com/img2.jpg\",\n  \"price\": 749.99,\n  \"inventoryCount\": 8\n}"
        }
      }
    },
    {
      "name": "Products - Delete (Admin)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/products/{{productId}}"
      }
    },
    {
      "name": "Cart - Get Mine",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/cart"
      }
    },
    {
      "name": "Cart - Add Item",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": "{{baseUrl}}/api/cart",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": 1,\n  \"quantity\": 1\n}"
        }
      }
    },
    {
      "name": "Cart - Update Quantity",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": "{{baseUrl}}/api/cart/{{cartItemId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": 1,\n  \"quantity\": 2\n}"
        }
      }
    },
    {
      "name": "Cart - Delete Item",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/cart/{{cartItemId}}"
      }
    },
    {
      "name": "Cart - Clear Mine",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/cart"
      }
    },
    {
      "name": "Orders - Create From Cart",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/orders"
      }
    },
    {
      "name": "Orders - Mine",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/orders/mine"
      }
    },
    {
      "name": "Orders - All (Admin)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/orders"
      }
    }
  ]
}
